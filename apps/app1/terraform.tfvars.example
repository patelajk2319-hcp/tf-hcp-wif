tfc_organization = "my-org"

# GitHub Enterprise Cloud
github_organization = "my-ghec-org"
nonprod_team_slug   = "developers"
prod_team_slug      = "release-managers"
repo_description    = "Infrastructure for app1"
# repo_visibility   = "internal"   # default — internal is recommended for GHEC

# GCP project IDs
dev_project_id  = "app1-dev"
test_project_id = "app1-test"
qa_project_id   = "app1-qa"
prod_project_id = "app1-prod"

